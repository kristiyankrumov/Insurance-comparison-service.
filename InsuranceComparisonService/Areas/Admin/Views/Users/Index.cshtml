@model IEnumerable<InsuranceComparisonService.Models.ApplicationUser>
@{
    ViewData["Title"] = "Управление на потребители";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
    bool isSuperAdmin = ViewBag.IsSuperAdmin ?? false;
}

<h2 class="mb-4"><i class="bi bi-people text-warning"></i> Управление на потребители</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Имейл</th>
            <th>Имe</th>
            <th>Роля</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            var roles = userRoles != null && userRoles.ContainsKey(u.Id) ? userRoles[u.Id] : new List<string>();
            var roleLabel = roles.Contains("SuperAdmin") ? "SuperAdmin" : roles.Contains("Admin") ? "Admin" : "User";
            var badgeClass = roleLabel == "SuperAdmin" ? "bg-danger" : roleLabel == "Admin" ? "bg-warning text-dark" : "bg-secondary";

            <tr>
                <td>@u.Email</td>
                <td>@u.FirstName @u.LastName</td>
                <td><span class="badge @badgeClass">@roleLabel</span></td>
                <td>
                    @if (isSuperAdmin)
                    {
                        <div class="d-inline-flex gap-1 me-2">
                            <form asp-area="Admin" asp-controller="Users" asp-action="ChangeRole" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <input type="hidden" name="role" value="User" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary" @(roleLabel == "User" ? "disabled" : "")>User</button>
                            </form>
                            <form asp-area="Admin" asp-controller="Users" asp-action="ChangeRole" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <input type="hidden" name="role" value="Admin" />
                                <button type="submit" class="btn btn-sm btn-outline-warning" @(roleLabel == "Admin" ? "disabled" : "")>Admin</button>
                            </form>
                            <form asp-area="Admin" asp-controller="Users" asp-action="ChangeRole" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <input type="hidden" name="role" value="SuperAdmin" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" @(roleLabel == "SuperAdmin" ? "disabled" : "")>SuperAdmin</button>
                            </form>
                        </div>
                    }
                    <form asp-area="Admin" asp-controller="Users" asp-action="Delete" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@u.Id" />
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Сигурен ли си, че искаш да изтриеш потребителя?')">
                            <i class="bi bi-trash"></i> Изтрий
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
