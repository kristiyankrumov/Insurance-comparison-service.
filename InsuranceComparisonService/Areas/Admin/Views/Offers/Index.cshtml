@model IEnumerable<InsuranceComparisonService.Models.InsuranceOffer>
@{
    ViewData["Title"] = "Управление на оферти";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-gear text-warning"></i> Управление на оферти</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus"></i> Нова оферта</a>
</div>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Наименование</th>
            <th>Тип</th>
            <th>Компания</th>
            <th>Цена</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Title</td>
                <td>@(o.Type == InsuranceComparisonService.Models.InsuranceType.Kasko ? "Каско" :
                       o.Type == InsuranceComparisonService.Models.InsuranceType.Health ? "Здравна" :
                       o.Type == InsuranceComparisonService.Models.InsuranceType.Civil ? "Гражданска" : "Имуществена")</td>
                <td>@o.Company?.Name</td>
                <td>@o.Price лв.</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-warning">Редактирай</a>
                    <form asp-action="Delete" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@o.Id" />
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Сигурен ли си?')">Изтрий</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
