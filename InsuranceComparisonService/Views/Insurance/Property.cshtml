@model IEnumerable<InsuranceComparisonService.Models.InsuranceOffer>
@{
    ViewData["Title"] = "Имуществена Застраховка";
}

<h2 class="mb-4"><i class="bi bi-house text-success"></i> Имуществена Застраховка</h2>

<div class="alert alert-success mb-4">
    <i class="bi bi-info-circle"></i>
    <strong>Имуществената застраховка</strong> защитава твоя дом срещу пожар, наводнение, кражба и природни бедствия.
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white fw-bold">Филтри</div>
            <div class="card-body">
                <form method="get">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Минимална цена (лв.)</label>
                        <input type="number" name="minPrice" class="form-control" value="@Context.Request.Query["minPrice"]" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Максимална цена (лв.)</label>
                        <input type="number" name="maxPrice" class="form-control" value="@Context.Request.Query["maxPrice"]" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Компания</label>
                        <select name="companyId" class="form-select">
                            <option value="">Всички</option>
                            @foreach (var c in ViewBag.Companies as IEnumerable<InsuranceComparisonService.Models.InsuranceCompany> ?? new List<InsuranceComparisonService.Models.InsuranceCompany>())
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Филтрирай</button>
                    <a asp-action="Property" class="btn btn-outline-secondary w-100 mt-2">Изчисти</a>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        @if (!Model.Any())
        {
            <div class="alert alert-info">Няма намерени оферти по зададените критерии.</div>
        }
        else
        {
            <div class="row">
                @foreach (var offer in Model)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 shadow-sm">
                            <div class="card-header bg-success text-white">
                                <i class="bi bi-house-check"></i> Имуществена
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="card-title fw-bold">@offer.Title</h5>
                                    <input type="checkbox" class="form-check-input compare-check" value="@offer.Id" title="Избери за сравнение" />
                                </div>
                                <p class="text-muted small mb-1"><i class="bi bi-building"></i> @offer.Company?.Name</p>
                                <p class="text-success fw-bold fs-4">@offer.Price лв./год.</p>
                                <p class="small mb-1"><strong>Покритие:</strong> @offer.Coverage</p>
                                <p class="small text-muted">@offer.Description</p>
                            </div>
                            <div class="card-footer d-flex gap-2">
                                <a asp-controller="Insurance" asp-action="Details" asp-route-id="@offer.Id"
                                   class="btn btn-sm btn-success flex-fill">Детайли</a>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <form asp-controller="Favorite" asp-action="Add" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="offerId" value="@offer.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-heart"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div id="compareBar" class="alert alert-success d-none mt-3">
                <span id="compareText">Избери 2 оферти за сравнение</span>
                <a id="compareBtn" href="#" class="btn btn-success btn-sm ms-3 d-none">Сравни</a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    const checks = document.querySelectorAll('.compare-check');
    const bar = document.getElementById('compareBar');
    const btn = document.getElementById('compareBtn');
    const txt = document.getElementById('compareText');
    checks.forEach(c => c.addEventListener('change', () => {
        const sel = [...checks].filter(x => x.checked).map(x => x.value);
        if (sel.length > 0) {
            bar.classList.remove('d-none');
            txt.textContent = `Избрани: ${sel.length} оферти`;
            if (sel.length === 2) { btn.classList.remove('d-none'); btn.href = `/Insurance/Compare?id1=${sel[0]}&id2=${sel[1]}`; }
            else btn.classList.add('d-none');
            if (sel.length > 2) c.checked = false;
        } else bar.classList.add('d-none');
    }));
</script>
}
