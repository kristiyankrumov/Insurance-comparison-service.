@model InsuranceComparisonService.Models.InsuranceOffer
@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Начало</a></li>
        <li class="breadcrumb-item">
            @if (Model.Type == InsuranceComparisonService.Models.InsuranceType.Kasko)
            { <a asp-controller="Insurance" asp-action="Kasko">Каско</a> }
            else { <a asp-controller="Insurance" asp-action="Health">Здравна</a> }
        </li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@Model.Title</h4>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-6">
                        <p class="text-muted mb-1">Компания</p>
                        <p class="fw-bold">@Model.Company?.Name</p>
                    </div>
                    <div class="col-6">
                        <p class="text-muted mb-1">Вид застраховка</p>
                        <p class="fw-bold">@(Model.Type == InsuranceComparisonService.Models.InsuranceType.Kasko ? "Каско" :
                            Model.Type == InsuranceComparisonService.Models.InsuranceType.Health ? "Здравна" :
                            Model.Type == InsuranceComparisonService.Models.InsuranceType.Civil ? "Гражданска отговорност" : "Имуществена")</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <p class="text-muted mb-1">Годишна премия</p>
                        <p class="fw-bold text-primary fs-3">@Model.Price лв.</p>
                    </div>
                    <div class="col-6">
                        <p class="text-muted mb-1">Месечна вноска</p>
                        <p class="fw-bold text-success fs-5">@(Math.Round(Model.Price / 12, 2)) лв.</p>
                    </div>
                </div>
                <hr />
                <h6 class="fw-bold">Покритие</h6>
                <p>@Model.Coverage</p>
                <h6 class="fw-bold">Описание</h6>
                <p>@Model.Description</p>
                @if (!string.IsNullOrEmpty(Model.Conditions))
                {
                    <h6 class="fw-bold">Условия</h6>
                    <p class="text-muted">@Model.Conditions</p>
                }
            </div>
        </div>

        @if (Model.Reviews.Any())
        {
            <h5 class="fw-bold mb-3">Отзиви (@Model.Reviews.Count)</h5>
            @foreach (var review in Model.Reviews)
            {
                <div class="card mb-2 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <strong>@review.User?.Email</strong>
                            <span class="text-warning">
                                @for (int i = 0; i < review.Rating; i++) { <text>★</text> }
                            </span>
                        </div>
                        <p class="mb-0 mt-1">@review.Comment</p>
                    </div>
                </div>
            }
        }

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="card shadow-sm mt-3">
                <div class="card-header bg-light fw-bold">Остави отзив</div>
                <div class="card-body">
                    <form asp-action="AddReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="offerId" value="@Model.Id" />
                        <div class="mb-2">
                            <label class="form-label">Оценка</label>
                            <select name="rating" class="form-select">
                                @for (int i = 1; i <= 5; i++) { <option value="@i">@i ★</option> }
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Коментар</label>
                            <textarea name="comment" class="form-control" rows="3" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Изпрати</button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body text-center">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Favorite" asp-action="Add" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="offerId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger w-100 mb-2">
                            <i class="bi bi-heart"></i> Добави в Любими
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-100 mb-2">
                        Влез за да запазиш
                    </a>
                }
                <a href="@Model.Company?.Website" target="_blank" class="btn btn-success w-100">
                    <i class="bi bi-box-arrow-up-right"></i> Сайт на @Model.Company?.Name
                </a>
            </div>
        </div>
    </div>
</div>
