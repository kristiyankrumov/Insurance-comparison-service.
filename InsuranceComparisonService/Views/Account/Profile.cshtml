@model InsuranceComparisonService.Models.ApplicationUser
@{
    ViewData["Title"] = "Моят профил";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4><i class="bi bi-person-circle"></i> Моят профил</h4>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-4">Имe</dt>
                    <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>
                    <dt class="col-sm-4">Имейл</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                </dl>
                <hr />
                <a asp-controller="Favorite" asp-action="Index" class="btn btn-outline-danger">
                    <i class="bi bi-heart"></i> Моите любими
                </a>
            </div>
        </div>
    </div>
</div>
